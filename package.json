{
  "name": "ephemeral-skills",
  "version": "0.1.0",
  "description": "Selective, cache-aware eviction of a skill's SKILL.md from agent context after use — reference implementation of clear_skill_uses.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "start": "tsx cli/cli.tsx",
    "harness": "tsx cli/costHarness.ts",
    "gen:mock": "tsx cli/genMockConversation.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude-code",
    "claude-agent-sdk",
    "skills",
    "context-management",
    "context-editing"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@inkjs/ui": "^2.0.0",
    "dotenv": "^17.4.2",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "yaml": "^2.5.0"
  }
}
