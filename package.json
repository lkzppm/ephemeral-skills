{
  "name": "ephemeral-skills",
  "version": "0.1.0",
  "description": "Selective, cache-aware eviction of a skill's SKILL.md from agent context after use — reference implementation of clear_skill_uses.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "start": "tsx examples/cli.ts",
    "harness": "tsx examples/costHarness.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["claude-code", "claude-agent-sdk", "skills", "context-management", "context-editing"],
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "yaml": "^2.5.0"
  }
}
