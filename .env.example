# Credentials for the live CLI (`npm start`) and cost harness (`npm run harness`).
# Copy to `.env` and fill in. The pure core and `npm test` need none of this.
# `.env` is gitignored; this `.env.example` is the committed template.

# Standard path — your Anthropic API key from console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-...

# Alternative auth: a bearer token + custom endpoint (LLM gateway / proxy /
# self-hosted fronting). The loop reads these; use INSTEAD of the key above.
#
# NOTE: a Claude Pro/Max subscription or `claude -p` CANNOT drive this loop. It
# needs the raw Messages API — manual cache_control breakpoints and per-request
# cache_read/cache_creation usage — which the subscription and the Claude Code
# CLI do not expose. Use an API key, a gateway bearer token, or Bedrock/Vertex.
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=https://your-gateway.example.com

# Optional: cost-harness tail length (default 6).
# TAIL=12
